# Telegram
TELEGRAM_BOT_TOKEN=          # From @BotFather

# Kan API (MCP server)
KAN_BASE_URL=https://tasks.xdeca.com/api/v1  # Base URL for Kan API
KAN_API_KEY=                 # API key for Kan (x-api-key header)

# Outline API (MCP server)
OUTLINE_BASE_URL=https://kb.xdeca.com/api  # Base URL for Outline API
OUTLINE_API_KEY=             # Outline API bearer token

# Anthropic (for agent + vagueness detection)
CLAUDE_REFRESH_TOKEN=        # Claude Max OAuth refresh token

# Sprint timing
SPRINT_START_DATE=2025-01-05 # A known sprint start date (Sunday)

# Admin access (comma-separated Telegram user IDs)
ADMIN_USER_IDS=              # e.g., 123456789,987654321

# Playwright (web browsing)
PLAYWRIGHT_ENABLED=          # Set to "true" to enable web browsing tools
# PLAYWRIGHT_ALLOWED_ORIGINS=  # Optional: comma-separated origins to allow (e.g., "https://example.com,https://other.com")
# PLAYWRIGHT_BLOCKED_ORIGINS=  # Optional: comma-separated origins to block

# Radicale (calendar/contacts)
RADICALE_URL=https://dav.xdeca.com     # CalDAV/CardDAV server URL
RADICALE_USERNAME=pm-agent              # Radicale username
RADICALE_PASSWORD=                      # Radicale password (required to enable)
# RADICALE_CALENDAR_OWNER=             # Optional: access another user's calendars
# RADICALE_ADDRESS_BOOK_URL=           # Full URL to team contacts address book (e.g. https://dav.xdeca.com/pm-agent/team-contacts/)

# GitHub (code reading)
GITHUB_TOKEN=                # Fine-grained PAT (contents:read+write, issues:write, pull_requests:write)
# GITHUB_REPO=10xdeca/gremlin  # Default repo (owner/name)
# GITHUB_BRANCH=main            # Default branch

# Research agent (A2A protocol)
# RESEARCH_AGENT_URL=           # URL of the A2A research agent (e.g. http://localhost:4100)

# Contact scanner (passive image-to-contact detection)
CONTACT_SCANNER_ENABLED=false  # Background image scanning for contacts in group topics

# Optional
REMINDER_INTERVAL_HOURS=1    # How often to check for overdue tasks (default: 1)
DATABASE_PATH=./data/kan-bot.db  # SQLite database path
HEALTH_PORT=8080             # Health check server port (default: 8080)
DEPLOY_SHA=dev               # Git SHA of the deployed commit (set by CI)
