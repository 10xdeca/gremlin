# Telegram
TELEGRAM_BOT_TOKEN=          # From @BotFather

# Kan API (MCP server)
KAN_BASE_URL=https://tasks.xdeca.com/api/v1  # Base URL for Kan API
KAN_API_KEY=                 # API key for Kan (x-api-key header)

# Outline API (MCP server)
OUTLINE_BASE_URL=https://kb.xdeca.com/api  # Base URL for Outline API
OUTLINE_API_KEY=             # Outline API bearer token

# Anthropic (for agent + vagueness detection)
ANTHROPIC_API_KEY=           # Anthropic API key

# Sprint timing
SPRINT_START_DATE=2025-01-05 # A known sprint start date (Sunday)

# Admin access (comma-separated Telegram user IDs)
ADMIN_USER_IDS=              # e.g., 123456789,987654321

# Optional
REMINDER_INTERVAL_HOURS=1    # How often to check for overdue tasks (default: 1)
DATABASE_PATH=./data/kan-bot.db  # SQLite database path
